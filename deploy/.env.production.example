# .env สำหรับ production บน VPS — สร้างไฟล์ .env จากตัวนี้แล้วใส่ค่าจริง
# Postgres (รันใน docker บน VPS, bind 127.0.0.1 เท่านั้น)
DATABASE_URL=postgresql://geo:CHANGE_ME_PG_PASSWORD@127.0.0.1:5434/geo_platform

# คีย์ session + ใช้ derive คีย์เข้ารหัส WP credential — ตั้งให้ยาวสุ่ม
SESSION_SECRET=CHANGE_ME_LONG_RANDOM

# Search backend: ddgs (ฟรี) | brave | serper
GEO_SEARCH_BACKEND=ddgs
BRAVE_API_KEY=
SERPER_API_KEY=

# LLM เขียนคอนเทนต์: เว้นว่าง = ใช้ template; หรือชี้ cloud LLM (OpenAI-compatible)
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_MODEL=claude-haiku-4-5

# Auto-run มอนิเตอร์รายสัปดาห์ในแอป (เปิดไว้บน production)
GEO_AUTORUN=1
GEO_RUN_INTERVAL_DAYS=7
GEO_RUN_CHECK_HOURS=12
