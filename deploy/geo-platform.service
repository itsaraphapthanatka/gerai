[Unit]
Description=GEO Platform (FastAPI / เจอ.AI)
After=network.target

[Service]
# ปรับ User/Group ตามผู้ใช้บน VPS (เช่น www-data หรือผู้ใช้ที่ deploy)
User=geo
Group=geo
WorkingDirectory=/opt/geo-platform
ExecStart=/opt/geo-platform/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8095 --proxy-headers --forwarded-allow-ips=127.0.0.1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
