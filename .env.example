# GEO Platform — MVP config (คัดลอกเป็น .env แล้วแก้ค่า)
GEO_DB_PATH=./geo_platform.db
# ตั้ง DATABASE_URL = ใช้ Postgres (เช่น postgresql://user:pass@127.0.0.1:5433/geo_platform); เว้นว่าง = SQLite
DATABASE_URL=
GEO_SEARCH_LIMIT=8
SESSION_SECRET=เปลี่ยนเป็นข้อความสุ่มยาวๆ

# Search backend: ddgs (ฟรี, ดีฟอลต์) | brave | serper — ใส่คีย์แล้วเปลี่ยน backend เพื่อผลแม่นขึ้น
GEO_SEARCH_BACKEND=ddgs
BRAVE_API_KEY=
SERPER_API_KEY=

# Auto-run มอนิเตอร์ในแอป: 1=เปิด, ว่าง/0=ปิด (ดีฟอลต์ปิด) — หรือใช้ run_monitors.py กับ cron/scheduler
GEO_AUTORUN=0
GEO_RUN_INTERVAL_DAYS=7
GEO_RUN_CHECK_HOURS=12

# (ออปชัน) LLM ผ่าน LiteLLM — เว้นว่างได้ MVP จะใช้ heuristic วิเคราะห์ไปก่อน
LITELLM_BASE_URL=http://127.0.0.1:4003/v1
LITELLM_API_KEY=
LITELLM_MODEL=claude-haiku-4-5
